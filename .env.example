# Kalshi API credentials
# 1. Create an API key in your Kalshi account settings (Profile -> API Keys).
# 2. Download the private key file and save it (default name: private_key.pem)
#    inside the kalshi_pipeline/ directory.
# 3. Copy this file to ".env" and fill in the values below.

# The API Key ID shown in your Kalshi account (a UUID).
KALSHI_KEY_ID="your_kalshi_key_id_here"

# Path to your RSA private key file (relative to kalshi_pipeline/).
KALSHI_PRIVATE_KEY_PATH="private_key.pem"
